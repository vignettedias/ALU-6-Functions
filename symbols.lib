#encoding utf-8
#
# ALU4_CORE
#
DEF ALU4_CORE U 0 40 Y Y 1 F N
F0 "U" 0 450 50 H V C CNN
F1 "ALU4_CORE" 0 -450 50 H V C CNN
F2 "" 0 0 50 H I C CNN
F3 "" 0 0 50 H I C CNN
DRAW
S -400 350 400 -350 0 1 10 f
X A[3:0] 1 -650 250 250 R 50 50 1 1 I
X B[3:0] 2 -650 150 250 R 50 50 1 1 I
X OP[3:0] 3 -650 50 250 R 50 50 1 1 I
X VCC 4 0 600 250 D 50 50 1 1 W
X GND 5 0 -600 250 U 50 50 1 1 W
X Y[3:0] 6 650 250 250 L 50 50 1 1 O
X COUT 7 650 150 250 L 50 50 1 1 O
X NEG 8 650 50 250 L 50 50 1 1 O
X ZERO 9 650 -50 250 L 50 50 1 1 O
T 0 0 280 50 0 0 1 "4-Bit ALU" Normal 0 C C
T 0 0 200 50 0 0 1 "AND/OR/XOR/ADD-SUB" Normal 0 C C
T 0 0 120 50 0 0 1 "Operand Negation" Normal 0 C C
ENDDRAW
ENDDEF
