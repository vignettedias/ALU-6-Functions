(kicad_pcb
  (version 20221018)
  (generator "pcbnew")
  (general
    (thickness 1.6)
  )

  (paper "A4")

  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user)
    (33 "F.Adhes" user)
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user)
    (37 "F.SilkS" user)
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user)
    (41 "Cmts.User" user)
    (42 "Eco1.User" user)
    (43 "Eco2.User" user)
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user)
    (47 "F.CrtYd" user)
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )

  (setup
    (pad_to_mask_clearance 0)
    (solder_mask_min_width 0)
    (grid_origin 0 0)
  )

  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "A[3:0]")
  (net 4 "B[3:0]")
  (net 5 "OP[3:0]")
  (net 6 "Y[3:0]")
  (net 7 "COUT")
  (net 8 "NEG")
  (net 9 "ZERO")

  (gr_rect (start 40 40) (end 180 120)
    (stroke (width 0.15) (type default))
    (fill (type none))
    (layer "Edge.Cuts"))

  (gr_text "4-Bit ALU Concept PCB" (at 110 46 0)
    (layer "F.SilkS")
    (effects (font (size 1.5 1.5) (thickness 0.2))))

  (gr_text "Inputs: A[3:0], B[3:0], OP[3:0]" (at 80 60 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.12))))

  (gr_text "Outputs: Y[3:0], COUT, NEG, ZERO" (at 80 66 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.12))))

  (gr_text "Power Rails: VCC, GND" (at 80 72 0)
    (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.12))))

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical" (layer "F.Cu")
    (at 55 90 0)
    (attr through_hole)
    (property "Reference" "J1" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "A[3:0]" (at 0 10 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical" (layer "F.Cu")
    (at 70 90 0)
    (attr through_hole)
    (property "Reference" "J2" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "B[3:0]" (at 0 10 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical" (layer "F.Cu")
    (at 85 90 0)
    (attr through_hole)
    (property "Reference" "J3" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "OP[3:0]" (at 0 10 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Package_DIP:DIP-40_W15.24mm" (layer "F.Cu")
    (at 120 80 0)
    (attr through_hole)
    (property "Reference" "U1" (at 7.62 -3 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "ALU4_CORE" (at 7.62 50 0) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical" (layer "F.Cu")
    (at 165 90 0)
    (attr through_hole)
    (property "Reference" "J4" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "Y[3:0]" (at 0 10 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical" (layer "F.Cu")
    (at 150 90 0)
    (attr through_hole)
    (property "Reference" "J5" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "COUT/NEG/ZERO" (at 0 8 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )

  (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical" (layer "F.Cu")
    (at 100 90 0)
    (attr through_hole)
    (property "Reference" "J6" (at 0 -2.5 0) (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15))))
    (property "Value" "VCC/GND" (at 0 6 90) (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15))))
  )
)
